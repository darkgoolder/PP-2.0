# ============================================
# НАСТРОЙКИ API
# ============================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=Wagon Classification API
VERSION=2.0.0
APP_ENV=development
DEBUG=True

# ============================================
# НАСТРОЙКИ МОДЕЛИ
# ============================================
MODEL_PATH=./models/best_model.pth
CLASS_NAMES=pered,zad,none

# ============================================
# БЕЗОПАСНОСТЬ И JWT
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_API_TOKEN=your-admin-api-token-change-this-in-production

# ============================================
# НАСТРОЙКИ ЗАГРУЗКИ ФАЙЛОВ
# ============================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.bmp

# ============================================
# ЛОГИРОВАНИЕ
# ============================================
LOG_LEVEL=INFO

# ============================================
# БАЗА ДАННЫХ (PostgreSQL)
# ============================================
DB_HOST=db  # ← ИЗМЕНИТЬ localhost НА db (для Docker)
DB_PORT=5432
DB_USER=wagon_user
DB_PASSWORD=wagon_pass
DB_NAME=wagon_db
DB_TYPE=postgresql

# URL базы данных (формируются автоматически)
DATABASE_URL=postgresql+asyncpg://wagon_user:wagon_pass@db:5432/wagon_db  # ← ИЗМЕНИТЬ localhost НА db
DATABASE_URL_SYNC=postgresql://wagon_user:wagon_pass@db:5432/wagon_db      # ← ИЗМЕНИТЬ localhost НА db

# Пул соединений
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=False

# ============================================
# SQLite (Альтернатива - закомментируйте PostgreSQL)
# ============================================
# DB_TYPE=sqlite
# SQLITE_PATH=./data/wagon.db

# ============================================
# MINIO S3 ХРАНИЛИЩЕ
# ============================================
# Подключение к MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False
MINIO_REGION=us-east-1

# S3 Бакеты
SECRETS_BUCKET=wagon-secrets
S3_BUCKET_IMAGES=wagon-images
S3_BUCKET_MODELS=wagon-models
S3_BUCKET_BACKUPS=wagon-backups

# Хранилище секретов
SECRETS_S3_PATH=secrets/encrypted.json

# Настройки URL
S3_URL_EXPIRE_HOURS=24

# ============================================
# REDIS (Опционально - для кэширования)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# ШИФРОВАНИЕ (для секретов)
# ============================================
# Ключ шифрования создаётся автоматически по пути ~/.wagon_encryption_key
# Не храните его в этом файле

# ============================================
# ИНСТРУКЦИИ
# ============================================
# 1. Скопируйте этот файл в .env
# 2. Замените все пароли и секретные ключи
# 3. Для production используйте надёжные пароли
# 4. Сгенерируйте SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 5. Сгенерируйте ADMIN_API_TOKEN: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 6. Запустите MinIO:
#    docker run -d --name wagon-minio -p 9000:9000 -p 9001:9001 \
#      -e "MINIO_ROOT_USER=minioadmin" -e "MINIO_ROOT_PASSWORD=minioadmin123" \
#      -v minio_data:/data minio/minio server /data --console-address ":9001"