# ============================================
# API SETTINGS
# ============================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=Wagon Classification API
VERSION=2.0.0
APP_ENV=development
DEBUG=True

# ============================================
# MODEL SETTINGS
# ============================================
MODEL_PATH=./models/best_model.pth
CLASS_NAMES=pered,zad,none

# ============================================
# SECURITY & JWT
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_API_TOKEN=your-admin-api-token-change-this-in-production

# ============================================
# UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.bmp

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1:8000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=wagon_user
DB_PASSWORD=wagon_pass
DB_NAME=wagon_db
DB_TYPE=postgresql

# Database URLs (constructed automatically)
DATABASE_URL=postgresql+asyncpg://wagon_user:wagon_pass@localhost:5432/wagon_db
DATABASE_URL_SYNC=postgresql://wagon_user:wagon_pass@localhost:5432/wagon_db

# Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=False

# ============================================
# SQLite (Alternative - comment PostgreSQL)
# ============================================
# DB_TYPE=sqlite
# SQLITE_PATH=./data/wagon.db

# ============================================
# MINIO S3 STORAGE (NEW)
# ============================================
# MinIO Connection
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False
MINIO_REGION=us-east-1

# S3 Buckets
SECRETS_BUCKET=wagon-secrets
S3_BUCKET_IMAGES=wagon-images
S3_BUCKET_MODELS=wagon-models
S3_BUCKET_BACKUPS=wagon-backups

# Secrets Storage
SECRETS_S3_PATH=secrets/encrypted.json

# URL Settings
S3_URL_EXPIRE_HOURS=24

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# ENCRYPTION (for secrets)
# ============================================
# Encryption key is auto-generated at ~/.wagon_encryption_key
# Do not store in this file

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file to .env
# 2. Change all passwords and secret keys
# 3. For production, use strong passwords
# 4. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 5. Start MinIO first: docker run -d --name wagon-minio -p 9000:9000 -p 9001:9001 -e "MINIO_ROOT_USER=minioadmin" -e "MINIO_ROOT_PASSWORD=minioadmin123" -v minio_data:/data minio/minio server /data --console-address ":9001"